    { "src": "/bilal", "dest": "/bilal.js" },
    { "src": "/hamid", "dest": "/hamid.js" },
    { "src": "/Aman", "dest": "/Aman.js" },
    { "src": "/Salam", "dest": "/Salam.js" },
    { "src": "/Aizaz", "dest": "/Aizaz.js" },
    { "src": "/Jangeera", "dest": "/Jangeera.js" },
    { "src": "/faisal", "dest": "/faisal.js" }
  ]
}
